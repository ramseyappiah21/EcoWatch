{
  "name": "ecowatch-api",
  "version": "1.0.0",
  "description": "EcoWatch Tarkwa REST API — PostgreSQL + object storage",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:seed-reports": "node scripts/seed-demo-reports.js",
    "ml:hotspot-train": "cd ../ml/hotspot && python -m pip install -r requirements.txt && python train.py --database",
    "test:api": "node scripts/api-test.js",
    "apk:publish": "node -e \"const fs=require('fs');const path=require('path');const src=path.join('..','build','app','outputs','flutter-apk','app-release.apk');const dir=path.join(__dirname,'downloads');fs.mkdirSync(dir,{recursive:true});fs.copyFileSync(src,path.join(dir,'EcoWatch.apk'));console.log('Published backend/downloads/EcoWatch.apk');\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.3",
    "uuid": "^11.1.0"
  }
}
